{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tauri Todo Course",
  "version": "0.1.0",
  "identifier": "com.example.tauritodocourse",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "beforeBundleCommand": "node scripts/prepare-tauri-bundle.mjs",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tauri Todo Course",
        "width": 1040,
        "height": 760,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": ["desktop-main", "desktop-window-state"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
